APP_NAME=Getfy

APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# IP do servidor para áreas de membros com subdomínio/domínio próprio (opcional).
# Se não definir, o sistema tenta obter do APP_URL. Use se o DNS do APP_URL não resolver para o IP correto.
# MEMBER_AREA_IP=203.0.113.50

# Fuso horário para filtros "hoje/ontem" e datas. Use America/Sao_Paulo para Brasil.
APP_TIMEZONE=America/Sao_Paulo
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=infoprodutor
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
# Em produção, use true para criptografar dados da sessão
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Para usar Redis em sessões: SESSION_DRIVER=redis e SESSION_STORE=redis (o store "redis" em config/cache.php)

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Em produção com Redis: QUEUE_CONNECTION=redis
QUEUE_CONNECTION=database

CACHE_STORE=database
# Em produção com Redis: CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Configuração Redis para produção (quando CACHE_STORE=redis, SESSION_DRIVER=redis, QUEUE_CONNECTION=redis):
# REDIS_CACHE_CONNECTION=cache
# REDIS_QUEUE_CONNECTION=default

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@getfy.com"
MAIL_FROM_NAME="Getfy"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Token para a URL do cron (E-mail Marketing). Se definido, gera URL em /email-marketing > Configuração.
# Ex.: CRON_SECRET=seu_token_secreto
# CRON_SECRET=

# PWA Painel: chaves VAPID para notificações push (vendas, PIX gerado).
# Gere em https://vapidkeys.com/ ou via: npx web-push generate-vapid-keys
# PWA_VAPID_PUBLIC=
# PWA_VAPID_PRIVATE=

# Loja de plugins — URL do plugins-getfy para a aba "Loja de plugins" (ex.: http://plugins-getfy.test).
# Obrigatório para ver plugins na aba; sem isso a lista fica vazia.
PLUGIN_STORE_URL=
PLUGIN_STORE_API_KEY=
PLUGIN_STORE_SUBMIT_URL=
